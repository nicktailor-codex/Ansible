#!/usr/bin/env bash
# slurm-allow — manage a Slurm partition's AllowAccounts at runtime.
#
# Subcommands:
#   slurm-allow show <partition>
#   slurm-allow add <partition> <account>           # add one account, keep the rest
#   slurm-allow remove <partition> <account>        # remove one account
#   slurm-allow set <partition> <a1,a2,a3>          # replace whole list
#   slurm-allow open <partition>                    # back to AllowAccounts=ALL
#
# Each subcommand validates accounts via `sacctmgr show account` before
# applying. Changes are RUNTIME-ONLY (scontrol update) — they revert if
# slurmctld restarts or `ansible-playbook playbooks/slurm.yml` re-templates
# slurm.conf. To persist, also update AllowAccounts in:
#   ~/ansible-dev/roles/slurm/files/slurm.conf

set -euo pipefail

die()  { echo "ERROR: $*" >&2; exit 1; }
note() { echo "NOTE:  $*" >&2; }

usage() {
    sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
    exit 1
}

[[ $# -lt 2 ]] && usage
CMD="$1"; PART="$2"

# verify partition exists
sudo scontrol show partition "$PART" >/dev/null 2>&1 \
    || die "partition '$PART' not found"

current_accounts() {
    sudo scontrol show partition "$PART" \
        | grep -oE 'AllowAccounts=\S+' \
        | sed 's/AllowAccounts=//'
}

apply_accounts() {
    local new="$1"
    sudo scontrol update PartitionName="$PART" AllowAccounts="$new" \
        || die "scontrol update failed"
    echo "Updated $PART AllowAccounts → $new"
    note "this is runtime-only. To persist across slurmctld restarts and"
    note "ansible reapplies, also update AllowAccounts in slurm.conf via the role:"
    note "  ~/ansible-dev/roles/slurm/files/slurm.conf"
}

validate_account() {
    local a="$1"
    [[ "$a" == "ALL" ]] && return 0
    sudo -u slurm sacctmgr show account format=Account -n -P 2>/dev/null \
        | grep -qxF "$a" \
        || die "account '$a' doesn't exist in slurmdbd — check with: sacctmgr show account"
}

case "$CMD" in
    show)
        echo "$PART: AllowAccounts=$(current_accounts)"
        ;;
    add)
        [[ $# -lt 3 ]] && die "usage: slurm-allow add <partition> <account>"
        ACCT="$3"
        validate_account "$ACCT"
        CUR="$(current_accounts)"
        if [[ "$CUR" == "ALL" ]]; then
            apply_accounts "$ACCT"
        elif [[ ",$CUR," == *",$ACCT,"* ]]; then
            echo "$ACCT already in $PART AllowAccounts; no change"
        else
            apply_accounts "$CUR,$ACCT"
        fi
        ;;
    remove)
        [[ $# -lt 3 ]] && die "usage: slurm-allow remove <partition> <account>"
        ACCT="$3"
        CUR="$(current_accounts)"
        [[ "$CUR" == "ALL" ]] && die "AllowAccounts is currently ALL; nothing to remove"
        NEW="$(echo "$CUR" | tr ',' '\n' | grep -vxF "$ACCT" | paste -sd, -)"
        [[ -z "$NEW" ]] && die "removing '$ACCT' would empty AllowAccounts — use 'slurm-allow open $PART' if you mean to allow everyone"
        [[ "$NEW" == "$CUR" ]] && { echo "$ACCT not in $PART AllowAccounts; no change"; exit 0; }
        apply_accounts "$NEW"
        ;;
    set)
        [[ $# -lt 3 ]] && die "usage: slurm-allow set <partition> <account1,account2,...>"
        IFS=, read -ra ACCTS <<< "$3"
        for a in "${ACCTS[@]}"; do validate_account "$a"; done
        apply_accounts "$3"
        ;;
    open)
        apply_accounts "ALL"
        ;;
    *)
        usage
        ;;
esac
